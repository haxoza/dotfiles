{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "caffeinate -ims </dev/null >/dev/null 2>&1 & disown",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pkill -f 'caffeinate -ims'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "ai-repo-audit@sunscrapers": true,
    "ai-team-toolkit@sunscrapers": true,
    "sdlc-toolkit@sunscrapers": true
  },
  "extraKnownMarketplaces": {
    "sunscrapers": {
      "source": {
        "source": "git",
        "url": "git@github.com:sunscrapers/agent-toolkit.git"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        "."
      ]
    },
    "excludedCommands": [
      "git",
      "gh"
    ]
  },
  "enableRemoteControl": true
}
