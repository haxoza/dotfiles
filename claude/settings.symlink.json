{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git tag*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git remote*)",
      "Bash(gh search:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh api:*)",
      "Bash(docker compose:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Read(~/.config/gcloud/**)",
      "Edit(~/.config/gcloud/**)",
      "Read(~/.config/op/**)",
      "Edit(~/.config/op/**)",
      "Read(~/.config/gh/**)",
      "Edit(~/.config/gh/**)",
      "Read(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Read(~/.terraform.d/**)",
      "Edit(~/.terraform.d/**)",
      "Read(~/.docker/config.json)",
      "Edit(~/.docker/config.json)",
      "Read(~/.pypirc)",
      "Edit(~/.pypirc)",
      "Read(~/.npmrc)",
      "Edit(~/.npmrc)",
      "Read(~/.git-credentials)",
      "Edit(~/.git-credentials)",
      "Read(~/Library/Keychains/**)",
      "Edit(~/Library/Keychains/**)",
      "Read(~/.azure/**)",
      "Edit(~/.azure/**)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(wget *|bash*)",
      "Bash(wget *| bash*)",
      "Bash(git push --force)",
      "Bash(git push --force )",
      "Bash(git push --force *)",
      "Bash(git push * --force)",
      "Bash(git push * --force )",
      "Bash(git push * --force *)",
      "Bash(git push -f)",
      "Bash(git push -f )",
      "Bash(git push -f *)",
      "Bash(git push * -f)",
      "Bash(git push * -f )",
      "Bash(git push * -f *)",
      "Bash(git reset --hard*)"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/caffeinate-manage.sh start",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/caffeinate-manage.sh stop",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ai-repo-audit@sunscrapers": true,
    "ai-team-toolkit@sunscrapers": true,
    "sdlc-toolkit@sunscrapers": true,
    "ralph-loop@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "sunscrapers": {
      "source": {
        "source": "git",
        "url": "git@github.com:sunscrapers/agent-toolkit.git"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "codeload.github.com",
        "pypi.org",
        "files.pythonhosted.org",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "static.crates.io",
        "index.crates.io",
        "proxy.golang.org",
        "sum.golang.org",
        "index.golang.org",
        "storage.googleapis.com",
        "repo.hex.pm",
        "builds.hex.pm",
        "json.schemastore.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.local/state/fnm_multishells",
        "~/.npm/_cacache",
        "~/Library/Caches/uv"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.azure",
        "~/.config/gcloud",
        "~/.config/op",
        "~/.config/gh",
        "~/.kube",
        "~/.terraform.d",
        "~/.docker/config.json",
        "~/.git-credentials",
        "~/.npmrc",
        "~/.pypirc",
        "~/Library/Keychains"
      ]
    },
    "excludedCommands": [
      "git:*",
      "gpg:*",
      "gh:*"
    ]
  },
  "effortLevel": "xhigh",
  "preferredNotifChannel": "terminal_bell",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
